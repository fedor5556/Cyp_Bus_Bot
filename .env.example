# Traffic4Cyprus API Configuration

# Static GTFS URLs (split by city)
STATIC_GTFS_URL_TEMPLATE="https://www.motionbuscard.org.cy/opendata/downloadfile?file=GTFS%5C{siri_code}_google_transit.zip&rel=True"

# Real-Time GTFS URL (all routes)
GTFS_RT_URL="http://20.19.98.194:8328/Api/api/gtfs-realtime"

# Database Configuration (leave as-is for SQLite, or set a real PostgreSQL URL)
DATABASE_URL="postgresql://user:password@localhost:5432/bus_analysis"

# Telegram Bots
# Main public ETA bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Crash alert bot token (from @BotFather) - sends crash notifications
CRASH_BOT_TOKEN=your_crash_bot_token_here

# Chat ID where alerts are sent
TELEGRAM_CHAT_ID=your_chat_id_here

# Admin/Maintenance Bot
# Token for the admin deployment bot (from @BotFather)
ADMIN_BOT_TOKEN=your_admin_bot_token_here

# Comma-separated list of Telegram User IDs authorized to run admin commands.
# Also gates the GCS bootstrap/transfer commands on the public ETA bot
# (numeric IDs only, unforgeable). Empty => no admin (fails closed).
ADMIN_TELEGRAM_ID=your_telegram_user_id_here

# --- Backblaze B2 transfer layer (optional; see src/cloud_sync.py) ---
# Private bucket name for large-file transfers. NOT a secret (the bucket is
# private and key-scoped). If unset, the committed default in src/config.py is
# used; set this only to override without editing config.py.
B2_BUCKET=
# Path to the B2 application key json. Defaults to secrets/b2_key.json. The key
# is delivered out-of-band via Telegram (DM a .json to the bus bot, or /armb2) -
# never committed to git.
B2_KEY_PATH=
